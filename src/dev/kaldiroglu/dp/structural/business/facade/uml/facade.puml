@startuml Facade
skinparam classAttributeIconSize 0
title Facade — Business example (Java)

class CheckoutController {
  - checkout : CheckoutFacade
  + placeOrder(cart : Cart, paymentMethod : String, addressZip : String) : CheckoutResult
}
note top of CheckoutController : Client

class CheckoutFacade {
  - inventory : InventoryService
  - pricing : PricingService
  - tax : TaxService
  - payment : PaymentGateway
  - shipping : ShippingService
  - orders : OrderRepository
  - notify : NotificationService
  + placeOrder(cart : Cart, paymentMethod : String, addressZip : String) : CheckoutResult
}
note right of CheckoutFacade : Facade

class InventoryService {
  + reserve(cart : Cart) : String
  + release(reservationId : String) : void
}
note bottom of InventoryService : Subsystem

class PricingService {
  + price(cart : Cart) : BigDecimal
}
note bottom of PricingService : Subsystem

class TaxService {
  + tax(subtotal : BigDecimal, addressZip : String) : BigDecimal
}
note bottom of TaxService : Subsystem

class PaymentGateway {
  + charge(customerId : String, amount : BigDecimal, paymentMethod : String) : String
  + refund(paymentId : String) : void
}
note bottom of PaymentGateway : Subsystem

class ShippingService {
  + createShipment(orderId : String, addressZip : String) : String
}
note bottom of ShippingService : Subsystem

class OrderRepository {
  + save(orderId : String, cart : Cart, total : BigDecimal) : void
}
note bottom of OrderRepository : Subsystem

class NotificationService {
  + sendConfirmation(customerId : String, orderId : String) : void
}
note bottom of NotificationService : Subsystem

record Cart {
  + customerId : String
  + lines : List<CartLine>
}

interface CheckoutResult <<sealed>>
class "CheckoutResult.Placed" as Placed {
  + orderId : String
}
class "CheckoutResult.Failed" as Failed {
  + reason : Reason
  + detail : String
}

CheckoutController o--> CheckoutFacade
CheckoutFacade ..> InventoryService
CheckoutFacade ..> PricingService
CheckoutFacade ..> TaxService
CheckoutFacade ..> PaymentGateway
CheckoutFacade ..> ShippingService
CheckoutFacade ..> OrderRepository
CheckoutFacade ..> NotificationService
CheckoutFacade ..> Cart
CheckoutFacade ..> CheckoutResult
CheckoutResult <|.. Placed
CheckoutResult <|.. Failed

@enduml
